{
  "name": "ms-copilot",
  "displayName": "ms-copilot",
  "description": "Code generation using Codeparrot from HuggingFace",
  "publisher": "EdGoh95",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ms-copilot.get_suggestion",
        "title": "MS Code Suggestion"
      },
      {
        "command": "ms-copilot.logSelectedText",
        "title": "MS Selected Text"
      }
    ],
    "keybindings": [
      {
        "command": "ms-copilot.logSelectedText",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.9",
    "@types/node": "^20.x",
    "@types/vscode": "^1.95.0",
    "@typescript-eslint/eslint-plugin": "^8.10.0",
    "@typescript-eslint/parser": "^8.7.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^9.13.0",
    "glob": "^8.1.0",
    "mocha": "^10.8.2",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@huggingface/agents": "^0.0.5",
    "@huggingface/hub": "^0.8.4",
    "@huggingface/inference": "^2.6.1",
    "@remixproject/engine-vscode": "^0.3.8",
    "huggingface": "^1.4.0",
    "node-fetch": "^2.6.1",
    "path": "^0.12.7",
    "python-shell": "^5.0.0"
  }
}
